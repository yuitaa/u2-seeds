---
import fs from 'node:fs/promises';
import { translateWagon } from '../data/labels';

import '../styles/panel.css';

const mappingJson = JSON.parse(await fs.readFile('mapping.json', 'utf-8'));

const BIOME_WAGONS = new Set([
  'boiler',
  'boxcar',
  'cargo',
  'island',
  'lab',
  'loco',
  'monorail',
]);

const allWagons = Object.keys(mappingJson.wagons).sort();
const wagonOnly = allWagons.filter((k) => !BIOME_WAGONS.has(k));
const biomeWagons = allWagons
  .filter((k) => BIOME_WAGONS.has(k))
  .filter((k) => k !== 'monorail');

const engines = Object.keys(mappingJson.engines).sort();
const versions = Object.keys(mappingJson.versions).sort();
---

<div id="filter-panel">
  <details open>
    <summary>絞り込み</summary>
    <div class="filter-body">
      <div class="filter-group">
        <strong>Engine</strong>
        <div class="checkboxes">
          {
            engines.map((key) => (
              <label>
                <input type="checkbox" name="engine" value={key} />
                {key}
              </label>
            ))
          }
        </div>
      </div>

      <div class="filter-group">
        <strong>Version</strong>
        <div class="checkboxes">
          {
            versions.map((key) => (
              <label>
                <input type="checkbox" name="version" value={key} />
                {key}
              </label>
            ))
          }
        </div>
      </div>

      <div class="filter-group wagon-group">
        <strong>Wagon（全て含む行のみ表示）</strong>
        <div class="tabs">
          <button class="tab-btn active" data-tab="wagon">Wagon</button>
          <button class="tab-btn" data-tab="biome">Biome</button>
        </div>
        <div class="tab-panel active" data-panel="wagon">
          <div class="checkboxes wagons">
            {
              wagonOnly.map((key) => (
                <label>
                  <input type="checkbox" name="wagon" value={key} />
                  {translateWagon(key)}
                </label>
              ))
            }
          </div>
        </div>
        <div class="tab-panel" data-panel="biome">
          <div class="checkboxes wagons">
            {
              biomeWagons.map((key) => (
                <label>
                  <input type="checkbox" name="wagon" value={key} />
                  {translateWagon(key)}
                </label>
              ))
            }
          </div>
        </div>
      </div>

      <div class="filter-group">
        <strong>表示設定</strong>
        <label>
          <input type="checkbox" id="hide-tasks" />
          Task列を非表示
        </label>
      </div>

      <button id="filter-reset">リセット</button>
    </div>
  </details>
</div>

<script>
  // タブ切り替え
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tabName = btn.dataset.tab!;
      const group = btn.closest('.wagon-group')!;
      group
        .querySelectorAll('.tab-btn')
        .forEach((b) => b.classList.remove('active'));
      group
        .querySelectorAll('.tab-panel')
        .forEach((p) => p.classList.remove('active'));
      btn.classList.add('active');
      group.querySelector(`[data-panel="${tabName}"]`)!.classList.add('active');
    });
  });

  // フィルター
  function applyFilter() {
    const selectedWagons = [
      ...document.querySelectorAll<HTMLInputElement>(
        'input[name="wagon"]:checked',
      ),
    ].map((el) => el.value);

    const selectedEngines = [
      ...document.querySelectorAll<HTMLInputElement>(
        'input[name="engine"]:checked',
      ),
    ].map((el) => el.value);

    const selectedVersions = [
      ...document.querySelectorAll<HTMLInputElement>(
        'input[name="version"]:checked',
      ),
    ].map((el) => el.value);

    const rows = document.querySelectorAll<HTMLTableRowElement>('tbody tr');

    rows.forEach((row) => {
      const rowWagons = (row.dataset.wagon ?? '').split(',');
      const rowEngine = row.dataset.engine ?? '';
      const rowVersion = row.dataset.version ?? '';

      const wagonMatch =
        selectedWagons.length === 0 ||
        selectedWagons.every((w) => rowWagons.includes(w));
      const engineMatch =
        selectedEngines.length === 0 || selectedEngines.includes(rowEngine);
      const versionMatch =
        selectedVersions.length === 0 || selectedVersions.includes(rowVersion);

      row.style.display =
        wagonMatch && engineMatch && versionMatch ? '' : 'none';
    });

    const visible = [...rows].filter((r) => r.style.display !== 'none').length;
    const el = document.getElementById('result-count');
    if (el) el.textContent = `検索結果: ${visible} 件`;
  }

  document
    .querySelectorAll<HTMLInputElement>(
      'input[name="wagon"], input[name="engine"], input[name="version"]',
    )
    .forEach((cb) => cb.addEventListener('change', applyFilter));

  document.getElementById('filter-reset')?.addEventListener('click', () => {
    document
      .querySelectorAll<HTMLInputElement>(
        'input[name="wagon"], input[name="engine"], input[name="version"]',
      )
      .forEach((cb) => (cb.checked = false));
    applyFilter();
  });

  // Task列 表示/非表示
  const hideTasksCheckbox = document.getElementById(
    'hide-tasks',
  ) as HTMLInputElement | null;
  const STORAGE_KEY = 'u2:hide-tasks';

  function applyHideTasks(hide: boolean) {
    document.querySelectorAll('.table-wrap').forEach((el) => {
      el.classList.toggle('hide-tasks', hide);
    });
    hideTasksCheckbox!.checked = hide;
  }

  if (hideTasksCheckbox) {
    applyHideTasks(localStorage.getItem(STORAGE_KEY) === 'true');

    hideTasksCheckbox.addEventListener('change', () => {
      const hide = hideTasksCheckbox.checked;
      localStorage.setItem(STORAGE_KEY, String(hide));
      applyHideTasks(hide);
    });
  }

  applyFilter();
</script>
